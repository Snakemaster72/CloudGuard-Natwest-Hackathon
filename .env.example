# CloudGuard Environment Settings
# Copy this file to `.env` and fill in values.

# --- Required (for LLM explanations/chat) ---
# Leave empty to use deterministic fallback explanations.
GEMINI_API_KEY=

# Optional: Gemini model
GEMINI_MODEL=gemini-1.5-flash

# --- Local (non-Docker) service wiring (optional) ---
# When running each service directly on your machine.
ML_SERVICE_URL=http://localhost:8001
BACKEND_PORT=8000
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# --- Forecast defaults (used by legacy prototype / scripts) ---
CONFIDENCE_INTERVAL=0.9
FORECAST_PERIODS=28

# --- App metadata ---
APP_NAME=CloudGuard
DEBUG=True

# AWS Mock Configuration (if applicable in future)
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_here
# AWS_REGION=us-east-1
